<%= render 'form', locals: { step: step, steps: @steps } do |f| %>
  <%= render "podcast_steps/progress_bar", wizard_steps: @steps %>

  <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden p-6 space-y-8">
    <!-- Type of Media -->
    <div>
      <h3 class="text-lg font-medium text-gray-900 mb-3">Type of Media</h3>
      <p class="text-sm text-gray-600 mb-3">Choose whether this episode is audio or video.</p>
      <div class="flex gap-6">
        <label class="inline-flex items-center gap-2">
          <%= f.radio_button :media_type, "audio", class: "h-4 w-4 rounded-full border-gray-300 text-orange-600 focus:ring-orange-500" %>
          <span class="text-sm text-gray-800">Audio</span>
        </label>
        <label class="inline-flex items-center gap-2">
          <%= f.radio_button :media_type, "video", class: "h-4 w-4 rounded-full border-gray-300 text-orange-600 focus:ring-orange-500" %>
          <span class="text-sm text-gray-800">Video</span>
        </label>
      </div>
      <% if @episode.errors[:media_type].any? %>
        <p class="mt-1 text-sm text-red-600"><%= @episode.errors[:media_type].join(", ") %></p>
      <% end %>
    </div>

    <!-- Cover Art -->
    <%= render "shared/file_upload",
          form: f,
          attachment_name: :cover_art,
          multiple: false,
          accept: "image/png,image/jpeg,image/webp",
          existing_files: @episode.cover_art.attached? ? [@episode.cover_art] : [],
          label_param: "cover_art_labels",
          section_label: "Cover Art",
          instructions: "Drag and drop your cover image here, or",
          hint: "PNG, JPG, or WEBP. If no episode cover art is selected, we will default to the podcast cover art." %>
    <%= hidden_field_tag "episode[remove_cover_art]", "0", id: "episode_remove_cover_art" %>

    <!-- Assets -->
    <%= render "shared/file_upload",
          form: f,
          attachment_name: :assets,
          multiple: true,
          accept: "audio/*,video/*,.mp3,.mp4,.wav,.mpg,.mov",
          existing_files: @episode.assets.attachments,
          delete_url: wizard_destroy_asset_path(podcast_id: @podcast.id, episode_id: @episode.id, attachment_id: ":id"),
          label_param: "asset_labels",
          section_label: "Upload Assets",
          instructions: "Drag and drop audio/video files here, or",
          hint: "Accepted file types: MP3, MP4, WAV, MPG, MOV" %>

  </div>

  <%= render "episode_steps/pagination", f: f, step: step %>
<% end %>
